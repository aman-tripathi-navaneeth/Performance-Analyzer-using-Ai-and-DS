# Performance Analyzer - Environment Variables Template
# Copy this file to .env and fill in your values

# Gemini AI API Key (get from: https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=models/gemini-2.0-flash-lite
GEMINI_MAX_OUTPUT_TOKENS=768

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Database (default: SQLite for local dev | change to PostgreSQL for production)
# For SQLite (default - no extra setup needed):
DATABASE_URL=sqlite:///./performance_analyzer.db

# For PostgreSQL (uncomment and fill for production):
# DATABASE_URL=postgresql://username:password@localhost:5432/performance_analyzer_db
